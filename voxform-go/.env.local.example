# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
APP_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# ── Database (XAMPP MySQL) ─────────────────────────────────────────────────────
DATABASE_DSN=root:@tcp(127.0.0.1:3306)/voxform?parseTime=true&charset=utf8mb4&collation=utf8mb4_unicode_ci

# ── JWT ────────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=replace-with-openssl-rand-hex-64-output
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# ── Storage (local filesystem) ────────────────────────────────────────────────
STORAGE_PATH=./storage
STORAGE_URL=http://localhost:4000/storage
MIGRATIONS_PATH=./migrations

# ── Audio transcription ────────────────────────────────────────────────────────
# Free at console.groq.com — no credit card required
# Leave empty to skip transcription:
GROQ_API_KEY=

# ── AI extraction (optional) ──────────────────────────────────────────────────
# Leave empty to skip extraction during development:
ANTHROPIC_API_KEY=
